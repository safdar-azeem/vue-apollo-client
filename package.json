{
  "name": "vue-apollo-client",
  "version": "1.0.7",
  "description": "Vue 3 Apollo Client with SSR, Codegen & Offline Support.",
  "author": "safdar-azeem",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vue-apollo-client.umd.js",
  "module": "./dist/vue-apollo-client.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-apollo-client.mjs",
      "require": "./dist/vue-apollo-client.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js",
      "types": "./dist/vite/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/safdar-azeem/vue-apollo-client.git"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "vue-router": "^4.0.0"
  },
  "dependencies": {
    "graphql": "^16.0.0",
    "@apollo/client": "^3.10.8",
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.0.0",
    "@graphql-codegen/typescript-vue-apollo": "^4.1.1",
    "@vue/apollo-composable": "^4.0.2",
    "apollo-upload-client": "^18.0.1",
    "graphql-tag": "^2.12.6",
    "js-cookie": "^3.0.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/apollo-upload-client": "^18.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.14.9",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.3.0",
    "vue-tsc": "^2.0.0"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "endOfLine": "auto",
    "bracketSameLine": true
  }
}
